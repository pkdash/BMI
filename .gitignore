# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Python cache / envs ---
__pycache__/
*.py[cod]
*$py.class
.python-version
.venv/
venv/
ENV/
env/

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.cache/

# --- Packaging artifacts ---
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# --- Native build artifacts (C/C++/Fortran/CMake/Make) ---
*.o
*.obj
*.a
*.la
*.lo
*.so
*.dylib
*.dll
*.mod
*.smod
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# --- Babelizer / generated wrapper outputs ---
# Keep source wrapper packages tracked, but ignore transient outputs.
**/build/
**/dist/
**/*.egg-info/
**/__pycache__/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Logs / local env files ---
*.log
.env
.env.*

